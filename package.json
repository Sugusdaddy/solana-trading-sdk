{
  "name": "@sugusdaddy/solana-trading-sdk",
  "version": "1.0.0",
  "description": "Professional-grade TypeScript SDK for building Solana trading bots",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "test": "vitest",
    "lint": "eslint src --ext ts",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@solana/web3.js": "^1.95.0",
    "@solana/spl-token": "^0.4.6",
    "@jup-ag/api": "^6.0.0",
    "bs58": "^5.0.0",
    "decimal.js": "^10.4.3",
    "eventemitter3": "^5.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.2.0",
    "eslint": "^8.56.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0"
  },
  "keywords": [
    "solana",
    "trading",
    "bot",
    "sdk",
    "jupiter",
    "raydium",
    "jito",
    "mev",
    "defi",
    "crypto"
  ],
  "author": "Sugusdaddy",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Sugusdaddy/solana-trading-sdk"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
